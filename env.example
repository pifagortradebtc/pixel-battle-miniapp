# Скопируйте в .env на сервере или задайте те же имена в панели хостинга (Environment).
# Секреты не публикуйте и не коммитьте в Git.
# Локально: скопируйте этот файл как `.env` и раскомментируйте нужные строки — `npm start` подхватит их автоматически.
# На облачном хостинге чаще задают переменные в веб-панели (там .env может не использоваться).

# Порт HTTP (хостинг часто подставляет свой — тогда PORT не трогайте)
# PORT=3847

# Публичный URL сайта (для редиректов оплаты и ссылок)
# PUBLIC_BASE_URL=https://ваш-домен.ru
# APP_URL=https://ваш-домен.ru

# --- Telegram Mini App / бот ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_IDS=123456789
# TELEGRAM_MINIAPP_LINK=https://t.me/ВашБот/игра
# Опционально: TELEGRAM_BOT_USERNAME= TELEGRAM_MINIAPP_SHORT_NAME=

# --- Несколько серверов (масштаб) ---
# REDIS_URL=redis://default:пароль@хост:6379
# REDIS_GAME_CHANNEL=pixel-battle:game
# На одном инстансе: CLUSTER_LEADER=true или не задавать.
# На остальных: CLUSTER_LEADER=false

# --- Платежи NOWPayments (если используете) ---
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_IPN_SECRET=
# NOWPAYMENTS_PAY_CURRENCY=usdtbsc
# NOWPAYMENTS_PRICE_CURRENCY=usdtbsc
# NOWPAYMENTS_SANDBOX=false

# --- Снимок карты после рестарта (лидер или один процесс) ---
# PIXELS_SNAPSHOT_DISABLE=false
# PIXELS_SNAPSHOT_DEBOUNCE_MS=3000
# PIXELS_SNAPSHOT_INTERVAL_MS=45000

# --- Нагрузка (опционально) ---
# Реже рассылать рейтинг (stats) всем WebSocket — меньше работы на телефонах (мс, по умолчанию ~420).
# STATS_BROADCAST_DEBOUNCE_MS=600
# PIXEL_BATCH_MAX_CELLS=800
# WS_MAX_CONN_PER_IP=40
# TRUST_PROXY=true
